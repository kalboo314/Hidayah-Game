# --- NetBeans ---
nbproject/
build/
dist/
nbbuild/

# --- Library eksternal (download manual) ---
lib/

# --- macOS ---
.DS_Store
.AppleDouble
.LSOverride

# --- Windows ---
Thumbs.db
ehthumbs.db
Desktop.ini

# --- Linux ---
*~

# --- Log files ---
*.log

# --- Package files ---
*.jar
*.war
*.ear
*.zip
*.tar.gz
*.rar

# --- File duplikat / backup ---
*copy*
*(1)*
*backup*